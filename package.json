{
  "name": "pactforge-sdk",
  "version": "1.0.0",
  "description": "TypeScript SDK for the PactForge Protocol on Stacks",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "stacks",
    "bitcoin",
    "escrow",
    "smart-contracts",
    "pactforge",
    "web3"
  ],
  "author": "PactForge",
  "license": "MIT",
  "dependencies": {
    "@stacks/common": "^7.3.1",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.4.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5"
  }
}
